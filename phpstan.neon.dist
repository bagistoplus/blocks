includes:
    - phpstan-baseline.neon

parameters:
    level: 5
    universalObjectCratesClasses:
        - BagistoPlus\Visual\Data\BlockData
        - Craftile\Laravel\PropertyBag
        - Craftile\Core\Data\PropertyBag
    paths:
        - src
        - config
    tmpDir: build/phpstan
    checkOctaneCompatibility: true
    checkModelProperties: true
